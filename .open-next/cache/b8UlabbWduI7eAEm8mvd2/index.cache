{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"es\" class=\"pt_sans_f10a5c9f-module__hnyLCW__variable h-full antialiased scroll-smooth\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/536b4d72a397ec90-s.p.27c8-9qx-v7kc.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/f05228a5f9ec0eae-s.p.3kxgs-7nixrf6.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/dashboard.png\" as=\"image\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/09r_g7p8ldta5.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/3z5q_p4msz2ha.js\"/><script src=\"/_next/static/chunks/15orcrkp-_9ct.js\" async=\"\"></script><script src=\"/_next/static/chunks/2nykiepra7i1k.js\" async=\"\"></script><script src=\"/_next/static/chunks/07u_h6i539_wj.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3gtektv3c62t6.js\" async=\"\"></script><script src=\"/_next/static/chunks/05-c3ty_6dwfk.js\" async=\"\"></script><script src=\"/_next/static/chunks/14mrh2-p_w84d.js\" async=\"\"></script><script src=\"/_next/static/chunks/2fqlcr-ia71j-.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>SellAlleS — Punto de Venta en la nube para tu negocio en RD</title><meta name=\"description\" content=\"POS web multi-sucursal con inventario, crédito, reportes y facturación electrónica DGII. Empieza gratis.\"/><meta property=\"og:title\" content=\"SellAlleS — Punto de Venta en la nube para tu negocio en RD\"/><meta property=\"og:description\" content=\"POS web multi-sucursal con inventario, crédito, reportes y facturación electrónica DGII. Empieza gratis.\"/><meta property=\"og:locale\" content=\"es_DO\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"SellAlleS — Punto de Venta en la nube para tu negocio en RD\"/><meta name=\"twitter:description\" content=\"POS web multi-sucursal con inventario, crédito, reportes y facturación electrónica DGII. Empieza gratis.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col bg-background text-foreground\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen flex flex-col font-sans\"><header class=\"sticky top-0 z-50 w-full border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60\"><div class=\"container mx-auto px-4 h-16 flex items-center justify-between\"><div class=\"flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-store h-6 w-6 text-primary\" aria-hidden=\"true\"><path d=\"M15 21v-5a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v5\"></path><path d=\"M17.774 10.31a1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.451 0 1.12 1.12 0 0 0-1.548 0 2.5 2.5 0 0 1-3.452 0 1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.77-3.248l2.889-4.184A2 2 0 0 1 7 2h10a2 2 0 0 1 1.653.873l2.895 4.192a2.5 2.5 0 0 1-3.774 3.244\"></path><path d=\"M4 10.95V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8.05\"></path></svg><span class=\"text-xl font-bold tracking-tight\">SellAlleS</span></div><nav class=\"hidden md:flex items-center gap-6 text-sm font-medium\"><a class=\"hover:text-primary transition-colors\" href=\"#caracteristicas\">Características</a><a class=\"hover:text-primary transition-colors\" href=\"#precios\">Precios</a><a class=\"hover:text-primary transition-colors\" href=\"#faq\">Preguntas</a></nav><div class=\"flex items-center gap-4\"><a href=\"http://localhost:3000/login\" class=\"hidden sm:inline-flex text-sm font-medium hover:text-primary transition-colors\">Iniciar sesión</a><a href=\"http://localhost:3000/login\" class=\"inline-flex items-center justify-center rounded-md bg-accent px-4 py-2 text-sm font-medium text-white shadow hover:bg-accent-hover transition-colors\">Crear cuenta gratis</a></div></div></header><main class=\"flex-1\"><section class=\"py-20 md:py-28 overflow-hidden bg-white\"><div class=\"container mx-auto px-4 grid lg:grid-cols-2 gap-12 items-center\"><div class=\"max-w-2xl\"><h1 class=\"text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6\">El punto de venta que <span class=\"text-primary\">crece</span> con tu negocio.</h1><p class=\"text-lg md:text-xl text-gray-600 mb-8 leading-relaxed\">Vende, controla tu inventario y lleva tus cuentas desde la nube. Una o varias sucursales, sin instalar nada.</p><div class=\"flex flex-col sm:flex-row gap-4\"><a href=\"http://localhost:3000/login\" class=\"inline-flex items-center justify-center rounded-lg bg-accent px-6 py-3 text-base font-medium text-white shadow-lg hover:bg-accent-hover transition-colors\">Crear cuenta gratis<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right ml-2 h-5 w-5\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a><a class=\"inline-flex items-center justify-center rounded-lg border border-gray-200 bg-white px-6 py-3 text-base font-medium hover:bg-gray-50 transition-colors\" href=\"#demo\">Ver demo</a></div><div class=\"mt-8 flex items-center gap-4 text-sm text-gray-500 font-medium\"><span class=\"flex items-center gap-1.5\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-green-500\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Sin tarjeta de crédito</span><span class=\"flex items-center gap-1.5\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-green-500\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Cancela cuando quieras</span></div></div><div class=\"relative mx-auto w-full max-w-[600px] lg:max-w-none mt-8 lg:mt-0\"><div class=\"relative rounded-xl border border-gray-200 bg-white p-2 shadow-2xl\"><div class=\"absolute inset-0 bg-gradient-to-tr from-primary/10 to-accent/10 rounded-xl -z-10 transform translate-x-4 translate-y-4\"></div><img src=\"/dashboard.png\" alt=\"Dashboard de SellAlleS\" class=\"rounded-lg w-full h-auto object-cover\"/></div></div></div></section><section class=\"border-y border-gray-100 bg-gray-50 py-10\"><div class=\"container mx-auto px-4 text-center\"><p class=\"text-sm font-semibold text-gray-500 uppercase tracking-wider mb-6\">Hecho para negocios dominicanos</p><div class=\"flex flex-wrap justify-center gap-8 md:gap-16 opacity-60 grayscale\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-store h-8 w-8\" aria-hidden=\"true\"><path d=\"M15 21v-5a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v5\"></path><path d=\"M17.774 10.31a1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.451 0 1.12 1.12 0 0 0-1.548 0 2.5 2.5 0 0 1-3.452 0 1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.77-3.248l2.889-4.184A2 2 0 0 1 7 2h10a2 2 0 0 1 1.653.873l2.895 4.192a2.5 2.5 0 0 1-3.774 3.244\"></path><path d=\"M4 10.95V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8.05\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-building2 lucide-building-2 h-8 w-8\" aria-hidden=\"true\"><path d=\"M10 12h4\"></path><path d=\"M10 8h4\"></path><path d=\"M14 21v-3a2 2 0 0 0-4 0v3\"></path><path d=\"M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2\"></path><path d=\"M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-package h-8 w-8\" aria-hidden=\"true\"><path d=\"M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z\"></path><path d=\"M12 22V12\"></path><polyline points=\"3.29 7 12 12 20.71 7\"></polyline><path d=\"m7.5 4.27 9 5.15\"></path></svg><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-users h-8 w-8\" aria-hidden=\"true\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"></path><path d=\"M16 3.128a4 4 0 0 1 0 7.744\"></path><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle></svg></div></div></section><section id=\"caracteristicas\" class=\"py-20 bg-white\"><div class=\"container mx-auto px-4\"><div class=\"text-center max-w-3xl mx-auto mb-16\"><h2 class=\"text-3xl md:text-4xl font-bold mb-4\">Todo lo que necesitas para operar</h2><p class=\"text-lg text-gray-600\">Herramientas poderosas diseñadas para la realidad de los negocios en República Dominicana.</p></div><div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\"><div class=\"p-6 rounded-2xl border border-gray-100 bg-white shadow-sm hover:shadow-md transition-shadow\"><div class=\"h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-store h-6 w-6 text-primary\" aria-hidden=\"true\"><path d=\"M15 21v-5a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v5\"></path><path d=\"M17.774 10.31a1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.451 0 1.12 1.12 0 0 0-1.548 0 2.5 2.5 0 0 1-3.452 0 1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.77-3.248l2.889-4.184A2 2 0 0 1 7 2h10a2 2 0 0 1 1.653.873l2.895 4.192a2.5 2.5 0 0 1-3.774 3.244\"></path><path d=\"M4 10.95V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8.05\"></path></svg></div><h3 class=\"text-xl font-bold mb-3\">POS rápido y ágil</h3><p class=\"text-gray-600 leading-relaxed\">Búsqueda por nombre o código de barras. Maneja varios carritos simultáneamente sin perder la venta.</p></div><div class=\"p-6 rounded-2xl border border-gray-100 bg-white shadow-sm hover:shadow-md transition-shadow\"><div class=\"h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-package h-6 w-6 text-primary\" aria-hidden=\"true\"><path d=\"M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z\"></path><path d=\"M12 22V12\"></path><polyline points=\"3.29 7 12 12 20.71 7\"></polyline><path d=\"m7.5 4.27 9 5.15\"></path></svg></div><h3 class=\"text-xl font-bold mb-3\">Inventario por sucursal</h3><p class=\"text-gray-600 leading-relaxed\">Controla tu stock en tiempo real. Traslada mercancía entre sucursales fácilmente.</p></div><div class=\"p-6 rounded-2xl border border-gray-100 bg-white shadow-sm hover:shadow-md transition-shadow\"><div class=\"h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-credit-card h-6 w-6 text-primary\" aria-hidden=\"true\"><rect width=\"20\" height=\"14\" x=\"2\" y=\"5\" rx=\"2\"></rect><line x1=\"2\" x2=\"22\" y1=\"10\" y2=\"10\"></line></svg></div><h3 class=\"text-xl font-bold mb-3\">Crédito y financiamiento</h3><p class=\"text-gray-600 leading-relaxed\">Crea planes de pago con cuotas e intereses. Lleva el control de tus cuentas por cobrar.</p></div><div class=\"p-6 rounded-2xl border border-gray-100 bg-white shadow-sm hover:shadow-md transition-shadow\"><div class=\"h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chart-column h-6 w-6 text-primary\" aria-hidden=\"true\"><path d=\"M3 3v16a2 2 0 0 0 2 2h16\"></path><path d=\"M18 17V9\"></path><path d=\"M13 17V5\"></path><path d=\"M8 17v-3\"></path></svg></div><h3 class=\"text-xl font-bold mb-3\">Reportes claros</h3><p class=\"text-gray-600 leading-relaxed\">Ventas por día, por sucursal, por producto y por vendedor. Toma decisiones con datos.</p></div><div class=\"p-6 rounded-2xl border border-gray-100 bg-white shadow-sm hover:shadow-md transition-shadow\"><div class=\"h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-building2 lucide-building-2 h-6 w-6 text-primary\" aria-hidden=\"true\"><path d=\"M10 12h4\"></path><path d=\"M10 8h4\"></path><path d=\"M14 21v-3a2 2 0 0 0-4 0v3\"></path><path d=\"M6 10H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2\"></path><path d=\"M6 21V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v16\"></path></svg></div><h3 class=\"text-xl font-bold mb-3\">Multi-sucursal</h3><p class=\"text-gray-600 leading-relaxed\">Administra todos tus locales desde una sola cuenta, con permisos por usuario.</p></div><div class=\"p-6 rounded-2xl border border-gray-100 bg-white shadow-sm hover:shadow-md transition-shadow\"><div class=\"h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-file-text h-6 w-6 text-primary\" aria-hidden=\"true\"><path d=\"M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z\"></path><path d=\"M14 2v5a1 1 0 0 0 1 1h5\"></path><path d=\"M10 9H8\"></path><path d=\"M16 13H8\"></path><path d=\"M16 17H8\"></path></svg></div><h3 class=\"text-xl font-bold mb-3\">Clientes y NCF</h3><p class=\"text-gray-600 leading-relaxed\">Genera comprobantes fiscales de la DGII cuando los necesites, o usa tickets simples.</p></div></div></div></section><section class=\"py-20 bg-background\"><div class=\"container mx-auto px-4\"><div class=\"text-center max-w-3xl mx-auto mb-16\"><h2 class=\"text-3xl md:text-4xl font-bold mb-4\">Empieza en minutos, no en meses</h2><p class=\"text-lg text-gray-600\">Un proceso de configuración simple para que comiences a facturar de inmediato.</p></div><div class=\"grid md:grid-cols-3 gap-12 max-w-5xl mx-auto\"><div class=\"text-center relative\"><div class=\"w-16 h-16 rounded-full bg-primary text-white text-2xl font-bold flex items-center justify-center mx-auto mb-6 relative z-10 shadow-lg\">1</div><h3 class=\"text-xl font-bold mb-3\">Crea tu cuenta</h3><p class=\"text-gray-600\">Regístrate gratis. No necesitas RNC ni estar formalizado para empezar a usar el sistema.</p></div><div class=\"text-center relative\"><div class=\"w-16 h-16 rounded-full bg-primary text-white text-2xl font-bold flex items-center justify-center mx-auto mb-6 relative z-10 shadow-lg\">2</div><h3 class=\"text-xl font-bold mb-3\">Agrega tus datos</h3><p class=\"text-gray-600\">Configura tus sucursales y carga tus primeros productos al inventario.</p></div><div class=\"text-center relative\"><div class=\"w-16 h-16 rounded-full bg-primary text-white text-2xl font-bold flex items-center justify-center mx-auto mb-6 relative z-10 shadow-lg\">3</div><h3 class=\"text-xl font-bold mb-3\">Empieza a vender</h3><p class=\"text-gray-600\">Abre tu caja y comienza a registrar ventas desde cualquier dispositivo.</p></div></div></div></section><section class=\"py-20 bg-primary/5 border-y border-primary/10\"><div class=\"container mx-auto px-4 grid md:grid-cols-2 gap-12 items-center\"><div><div class=\"inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary font-medium text-sm mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check h-4 w-4\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg>Cumplimiento Fiscal</div><h2 class=\"text-3xl md:text-4xl font-bold mb-6\">Formalízate a tu ritmo</h2><p class=\"text-lg text-gray-600 mb-6 leading-relaxed\">¿Aún no tienes RNC? No hay problema. <strong>Empieza a organizar tu negocio hoy mismo</strong> usando tickets internos.</p><p class=\"text-lg text-gray-600 mb-8 leading-relaxed\">Cuando estés listo para formalizarte, SellAlleS está preparado para emitir Comprobantes Fiscales (NCF) y Facturación Electrónica (e-CF, Ley 32-23) de la DGII con solo activar una opción.</p><ul class=\"space-y-3\"><li class=\"flex items-center gap-3 font-medium text-gray-800\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-5 w-5 text-green-500\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Opera con o sin RNC</li><li class=\"flex items-center gap-3 font-medium text-gray-800\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-5 w-5 text-green-500\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Listo para Facturación Electrónica</li><li class=\"flex items-center gap-3 font-medium text-gray-800\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-5 w-5 text-green-500\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Reportes para tu contable</li></ul></div><div class=\"relative\"><div class=\"bg-white p-8 rounded-2xl shadow-xl border border-gray-100\"><h3 class=\"font-bold text-xl mb-4 border-b pb-4\">Ejemplo de Ticket</h3><div class=\"space-y-4 text-sm font-mono text-gray-600\"><div class=\"text-center\"><p class=\"font-bold text-black text-base\">COLMADO EL PROGRESO</p><p>RNC: 132-XXXXX-X</p><p>Factura de Consumo</p><p>NCF: B0200000001</p></div><div class=\"border-t border-dashed pt-4\"><div class=\"flex justify-between\"><span>2x Refresco 20oz</span><span>RD$ 100.00</span></div><div class=\"flex justify-between\"><span>1x Pan de Agua</span><span>RD$  15.00</span></div><div class=\"flex justify-between\"><span>1x Salami (libra)</span><span>RD$ 120.00</span></div></div><div class=\"border-t border-dashed pt-4 font-bold text-black flex justify-between text-base\"><span>TOTAL</span><span>RD$ 235.00</span></div></div></div></div></div></section><section id=\"precios\" class=\"py-20 bg-white\"><div class=\"container mx-auto px-4\"><div class=\"text-center max-w-3xl mx-auto mb-16\"><h2 class=\"text-3xl md:text-4xl font-bold mb-4\">Planes simples y transparentes</h2><p class=\"text-lg text-gray-600\">Precios en pesos dominicanos. Sin cargos ocultos ni contratos amarrados.</p></div><div class=\"grid md:grid-cols-3 gap-8 max-w-6xl mx-auto items-center\"><div class=\"rounded-2xl border border-gray-200 bg-white p-8 shadow-sm\"><h3 class=\"text-xl font-bold mb-2\">Prueba Gratis</h3><p class=\"text-gray-500 text-sm mb-6\">Prueba todas las funciones por 14 días.</p><div class=\"mb-6\"><span class=\"text-4xl font-bold\">RD$ 0</span></div><ul class=\"space-y-4 mb-8\"><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> 1 Sucursal</li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> 2 Usuarios</li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Inventario completo</li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Sin tarjeta de crédito</li></ul><a href=\"http://localhost:3000/login\" class=\"block w-full py-2.5 px-4 rounded-lg border-2 border-primary text-primary font-semibold text-center hover:bg-primary/5 transition-colors\">Iniciar prueba</a></div><div class=\"rounded-2xl border-2 border-accent bg-white p-8 shadow-xl relative transform md:-translate-y-4\"><div class=\"absolute top-0 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-accent text-white px-4 py-1 rounded-full text-sm font-bold tracking-wide\">RECOMENDADO</div><h3 class=\"text-xl font-bold mb-2\">Pro</h3><p class=\"text-gray-500 text-sm mb-6\">Para negocios en crecimiento.</p><div class=\"mb-6\"><span class=\"text-4xl font-bold\">RD$ 1,900</span><span class=\"text-gray-500\">/mes</span></div><ul class=\"space-y-4 mb-8\"><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary shrink-0\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span>1 Sucursal <span class=\"text-gray-400 text-xs ml-1\">(pago extra por adicionales)</span></span></li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> 10 Usuarios</li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Crédito y financiamiento</li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Reportes avanzados</li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> NCF Tradicional</li></ul><a href=\"http://localhost:3000/login\" class=\"block w-full py-2.5 px-4 rounded-lg bg-accent text-white font-semibold text-center hover:bg-accent-hover transition-colors shadow-md\">Empezar ahora</a></div><div class=\"rounded-2xl border border-gray-200 bg-white p-8 shadow-sm\"><h3 class=\"text-xl font-bold mb-2\">Empresarial</h3><p class=\"text-gray-500 text-sm mb-6\">Para operaciones a gran escala.</p><div class=\"mb-6\"><span class=\"text-4xl font-bold\">A medida</span></div><ul class=\"space-y-4 mb-8\"><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Sucursales ilimitadas</li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Usuarios ilimitados</li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Facturación Electrónica (e-CF)</li><li class=\"flex items-center gap-3 text-sm\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check h-4 w-4 text-primary\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg> Soporte prioritario</li></ul><a href=\"https://wa.me/18299333226?text=Hola,%20me%20interesa%20cotizar%20el%20plan%20Empresarial%20de%20SellAlleS\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"block w-full py-2.5 px-4 rounded-lg bg-yellow-400 text-yellow-950 font-semibold text-center hover:bg-yellow-500 transition-colors shadow-md\">Cotizar</a></div></div></div></section><section id=\"faq\" class=\"py-20 bg-background\"><div class=\"container mx-auto px-4 max-w-3xl\"><div class=\"text-center mb-16\"><h2 class=\"text-3xl font-bold mb-4\">Preguntas Frecuentes</h2></div><div class=\"space-y-6\"><div class=\"bg-white p-6 rounded-xl shadow-sm border border-gray-100\"><h4 class=\"text-lg font-bold mb-2 flex items-start gap-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right h-5 w-5 text-primary shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg>¿Necesito estar formalizado en la DGII?</h4><p class=\"text-gray-600 pl-8\">No para empezar. Puedes usar SellAlleS para controlar tu inventario y ventas con tickets internos. Cuando te formalices, activamos la opción de NCF.</p></div><div class=\"bg-white p-6 rounded-xl shadow-sm border border-gray-100\"><h4 class=\"text-lg font-bold mb-2 flex items-start gap-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right h-5 w-5 text-primary shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg>¿Funciona si tengo varias sucursales?</h4><p class=\"text-gray-600 pl-8\">¡Sí! SellAlleS es multi-sucursal. Puedes ver el inventario y las ventas de cada local de forma independiente o consolidada desde tu misma cuenta.</p></div><div class=\"bg-white p-6 rounded-xl shadow-sm border border-gray-100\"><h4 class=\"text-lg font-bold mb-2 flex items-start gap-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right h-5 w-5 text-primary shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg>¿Mis datos están seguros?</h4><p class=\"text-gray-600 pl-8\">Totalmente. Tus datos están respaldados en la nube y asilados por empresa. Solo tú y los usuarios a los que les des permiso pueden acceder a tu información.</p></div><div class=\"bg-white p-6 rounded-xl shadow-sm border border-gray-100\"><h4 class=\"text-lg font-bold mb-2 flex items-start gap-3\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right h-5 w-5 text-primary shrink-0 mt-0.5\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg>¿Necesito instalar algún programa?</h4><p class=\"text-gray-600 pl-8\">No. SellAlleS funciona 100% en la web. Solo necesitas un navegador (Chrome, Safari, Edge) y conexión a internet para acceder desde tu PC, tablet o celular.</p></div></div></div></section><section class=\"py-20 bg-primary relative overflow-hidden\"><div class=\"absolute inset-0 bg-[url(&#x27;https://www.transparenttextures.com/patterns/cubes.png&#x27;)] opacity-10\"></div><div class=\"container mx-auto px-4 text-center relative z-10\"><h2 class=\"text-3xl md:text-5xl font-bold text-white mb-6\">Toma el control de tu negocio hoy</h2><p class=\"text-primary-foreground/90 text-lg md:text-xl mb-10 max-w-2xl mx-auto text-white\">Únete a cientos de dueños de negocios en República Dominicana que ya están vendiendo más y mejor con SellAlleS.</p><a href=\"http://localhost:3000/login\" class=\"inline-flex items-center justify-center rounded-lg bg-accent px-8 py-4 text-lg font-bold text-white shadow-xl hover:bg-accent-hover hover:scale-105 transition-all\">Empieza gratis hoy</a></div></section></main><footer class=\"bg-white border-t py-12\"><div class=\"container mx-auto px-4 grid md:grid-cols-4 gap-8\"><div class=\"col-span-1 md:col-span-2\"><div class=\"flex items-center gap-2 mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-store h-6 w-6 text-primary\" aria-hidden=\"true\"><path d=\"M15 21v-5a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v5\"></path><path d=\"M17.774 10.31a1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.451 0 1.12 1.12 0 0 0-1.548 0 2.5 2.5 0 0 1-3.452 0 1.12 1.12 0 0 0-1.549 0 2.5 2.5 0 0 1-3.77-3.248l2.889-4.184A2 2 0 0 1 7 2h10a2 2 0 0 1 1.653.873l2.895 4.192a2.5 2.5 0 0 1-3.774 3.244\"></path><path d=\"M4 10.95V19a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8.05\"></path></svg><span class=\"text-xl font-bold\">SellAlleS</span></div><p class=\"text-gray-500 text-sm max-w-xs mb-6\">El punto de venta web diseñado para impulsar el crecimiento de las PYMES en República Dominicana.</p></div><div><h4 class=\"font-bold mb-4\">Producto</h4><ul class=\"space-y-2 text-sm text-gray-500\"><li><a class=\"hover:text-primary\" href=\"#caracteristicas\">Características</a></li><li><a class=\"hover:text-primary\" href=\"#precios\">Precios</a></li><li><a class=\"hover:text-primary\" href=\"#\">Facturación e-CF</a></li></ul></div><div><h4 class=\"font-bold mb-4\">Contacto</h4><ul class=\"space-y-2 text-sm text-gray-500\"><li>Soporte Técnico</li><li>Ventas</li><li><a href=\"https://instagram.com/sellalles.rd\" class=\"hover:text-primary\">@sellalles.rd</a></li></ul></div></div><div class=\"container mx-auto px-4 mt-12 pt-8 border-t text-center text-sm text-gray-400\"><p>© <!-- -->2026<!-- --> SellAlleS. Todos los derechos reservados.</p></div></footer></div><!--$--><!--/$--><script src=\"/_next/static/chunks/3z5q_p4msz2ha.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n4:I[5014,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\",\\\"/_next/static/chunks/2fqlcr-ia71j-.js\\\"],\\\"default\\\"]\\n5:I[22016,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\",\\\"/_next/static/chunks/2fqlcr-ia71j-.js\\\"],\\\"\\\"]\\n16:I[68027,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/09r_g7p8ldta5.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/536b4d72a397ec90-s.p.27c8-9qx-v7kc.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n:HL[\\\"/_next/static/media/f05228a5f9ec0eae-s.p.3kxgs-7nixrf6.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"c\\\":[\\\"\\\",\\