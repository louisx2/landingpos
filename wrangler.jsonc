{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sellalles-landing",
  "compatibility_date": "2026-07-08",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "sellalles-landing"
    }
  ]
}
